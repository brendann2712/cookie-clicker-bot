def rotate_image(img, angle):
    """Rotate image by angle degrees around center."""
    h, w = img.shape[:2]
    center = (w // 2, h // 2)
    matrix = cv2.getRotationMatrix2D(center, angle, 1.0)
    rotated = cv2.warpAffine(img, matrix, (w, h), borderMode=cv2.BORDER_REPLICATE)
    return rotated
 
 
def precompute_templates(template_path):
    """Pre-generate all scaled and rotated versions of a template at startup."""
    if template_path in scaled_templates:
        return scaled_templates[template_path]
 
    if not os.path.exists(template_path):
        return None
 
    img = cv2.imread(template_path)
    if img is None:
        return None
 
    template_gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
 
    # Pre-compute all scaled + rotated versions
    templates = []
    for scale in SCALES:
        for rotation in ROTATIONS:
            # Scale is divided by 3 because screen is downsampled to 33%
            width = int(template_gray.shape[1] * scale / 3)
            height = int(template_gray.shape[0] * scale / 3)
            if width >= 10 and height >= 10:
                resized = cv2.resize(template_gray, (width, height))
                rotated = rotate_image(resized, rotation)
                templates.append((scale, rotation, width, height, rotated))
 
    scaled_templates[template_path] = templates
    print(f"Pre-computed {len(templates)} golden cookie templates ({len(SCALES)} scales x {len(ROTATIONS)} rotations)")
    return templates
 
 
def fast_screenshot_gray():
    """Take screenshot directly to grayscale using mss, downsampled 33% for speed."""
    with mss.mss() as sct:  # Create per-call (thread-safe)
        monitor = sct.monitors[1]  # Primary monitor
        img = np.array(sct.grab(monitor))
        gray = cv2.cvtColor(img, cv2.COLOR_BGRA2GRAY)
        # Downsample to 33% - matching is 9x faster on smaller image
        h, w = gray.shape
        return cv2.resize(gray, (w // 3, h // 3))
 
 
def find_image_multiscale(template_path, threshold=0.6):
    """Find an image on screen at multiple scales and rotations using OpenCV."""
    # Get pre-computed scaled + rotated templates
    templates = precompute_templates(template_path)
    if not templates:
        return None
 
    # Fast screenshot directly to grayscale
    screen_gray = fast_screenshot_gray()
    screen_h, screen_w = screen_gray.shape
 
    best_match = None
    best_val = 0
 
    # Check all pre-computed scales and rotations
    for scale, rotation, width, height, rotated in templates:
        # Skip if template is larger than screen
        if height > screen_h or width > screen_w:
            continue
 
        # Template matching
        result = cv2.matchTemplate(screen_gray, rotated, cv2.TM_CCOEFF_NORMED)
        min_val, max_val, min_loc, max_loc = cv2.minMaxLoc(result)
 
        if max_val > best_val and max_val >= threshold:
            best_val = max_val
            # Calculate center point (multiply by 3 to convert back to full screen coords)
            center_x = (max_loc[0] + width // 2) * 3
            center_y = (max_loc[1] + height // 2) * 3
            best_match = (center_x, center_y, max_val, scale, rotation)
 
            # Early termination - good enough match found
            if max_val > 0.7:
                return best_match
 
    return best_match
 
 
def detect_golden_cookies():
    """Background thread that scans for golden cookies."""
    global detecting, golden_cookies_clicked, last_golden_pos
 
    print("[Golden] Detection thread started (multi-scale)...")
 
    while detecting:
        try:
            result = find_image_multiscale(GOLDEN_COOKIE_IMAGE, GOLDEN_COOKIE_THRESHOLD)
 
            if result:
                x, y, confidence, scale, rotation = result
                # Only click if position is different from last click (50px tolerance)
                dist = ((x - last_golden_pos[0])**2 + (y - last_golden_pos[1])**2)**0.5
                if dist > 50:
                    print(f"[Golden] Found at ({x}, {y}) conf={confidence:.2f} scale={scale:.1f}x rot={rotation}")
                    pyautogui.click(x, y)
                    last_golden_pos = (x, y)
                    golden_cookies_clicked += 1
                    print(f"[Golden] Cookie #{golden_cookies_clicked} clicked!")
                    time.sleep(0.5)  # Brief pause after clicking to avoid double-clicks
 
            # No sleep needed - detection is fast enough (~130ms per cycle)
 
        except Exception as e:
            print(f"[Golden] Detection error: {e}")
            time.sleep(1)
 
    print("[Golden] Detection thread stopped.")
 
 

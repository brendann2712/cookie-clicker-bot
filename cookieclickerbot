        upgrade_status_label.config(text=f"Upgrades: {found_count}/{len(UPGRADE_IMAGES)} detected", fg="green")
    else:
        upgrade_status_label.config(text="Upgrades: None detected (using fallback)", fg="orange")
        # NEW: Test golden cookie detection (Lesson 2)
    print("\n  --- Golden Cookie Detection ---")
    if os.path.exists(GOLDEN_COOKIE_IMAGE):
        start = time.perf_counter()
        golden = find_image_multiscale(GOLDEN_COOKIE_IMAGE, GOLDEN_COOKIE_THRESHOLD)
        elapsed_ms = (time.perf_counter() - start) * 1000
        if golden:
            print(f"  Golden Cookie: FOUND at ({golden[0]}, {golden[1]}) conf={golden[2]:.2f} ({elapsed_ms:.0f}ms)")
        else:
            print(f"  Golden Cookie: not visible ({elapsed_ms:.0f}ms)")
    else:
        print("  Golden Cookie: IMAGE MISSING")
 

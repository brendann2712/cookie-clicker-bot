def run_cookie_bot():
    """Main bot loop."""
    global should_click_cookies, click_count, detecting
 
    print("Starting in 5 seconds... get Cookie Clicker ready!")
    time.sleep(5)
 
    print(f"Clicking! Upgrades every {UPGRADE_INTERVAL}s. Press ESC to stop.")
 
    # Start the CV monitoring thread for big cookie position
    cv_thread = threading.Thread(target=cookie_cv_monitor, daemon=True)
    cv_thread.start()
 
    # NEW: Start golden cookie detection thread (Lesson 2)
    detecting = True
    golden_thread = threading.Thread(target=detect_golden_cookies, daemon=True)
    golden_thread.start()
 
    last_upgrade_time = time.time()
    last_notification_check = time.time()
 
    while should_click_cookies:
        current_time = time.time()
 
        pyautogui.click(current_cookie_x, current_cookie_y)
        click_count += 1
 
        if current_time - last_notification_check >= NOTIFICATION_CHECK_INTERVAL:
            if close_notification():
                notif_count_label.config(text=f"Notifications closed: {notifications_closed}")
            last_notification_check = current_time
 
        if current_time - last_upgrade_time >= UPGRADE_INTERVAL:
            click_all_upgrades()
            last_upgrade_time = current_time
 
    # Stop golden cookie detection when clicking stops
    detecting = False
 
    print(f"Bot stopped. Clicks: {click_count}, Notifications closed: {notifications_closed}, Golden cookies clicked: {golden_cookies_clicked}")
 
 
def start_clicking_cookies():
    """Start the cookie bot in a background thread."""
    global should_click_cookies
 
    if should_click_cookies:
        print("Bot is already running!")
        return
 
    should_click_cookies = True
    bot_thread = threading.Thread(target=run_cookie_bot, daemon=True)
    bot_thread.start()
 
 
def stop_clicking_cookies():
    """Stop the cookie bot."""
    global should_click_cookies, detecting
    should_click_cookies = False
    detecting = False
    cv_status_label.config(text="Cookie: Stopped", fg="gray")
    print("Stopped!")
 
 
def click_all_upgrades():
    """Click upgrades using CV detection, with fallback to hardcoded positions."""
    global upgrades_detected_by_cv
 
    print("Buying upgrades...")
    detected_positions = detect_all_upgrades()
 
    cv_clicks = 0
    fallback_clicks = 0
 
    for i, cv_position in enumerate(detected_positions):
        if cv_position:
            pyautogui.click(cv_position[0], cv_position[1])
            cv_clicks += 1
        elif i < len(UPGRADE_Y_POSITIONS):
            pyautogui.click(UPGRADE_X_POSITION, UPGRADE_Y_POSITIONS[i])
            fallback_clicks += 1
        time.sleep(0.1)
 
    if cv_clicks > 0:
        upgrade_status_label.config(
            text=f"Upgrades: {cv_clicks} CV, {fallback_clicks} fallback",
            fg="green" if fallback_clicks == 0 else "orange"
        )
    else:
        upgrade_status_label.config(text="Upgrades: Using fallback", fg="orange")
 
 

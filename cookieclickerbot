def detect_image_on_screen(image_path, confidence=0.8):
    """Use OpenCV to find an image on the screen."""
    try:
        center = pyautogui.locateCenterOnScreen(image_path, confidence=confidence)
        if center:
            return (center.x, center.y)
        return None
    except pyautogui.ImageNotFoundException:
        return None
    except Exception as e:
        print(f"[CV Error] {e}")
        return None
 
 
def detect_big_cookie():
    """Try to find the big cookie on screen using CV."""
    if not os.path.exists(BIG_COOKIE_IMAGE):
        return None
    return detect_image_on_screen(BIG_COOKIE_IMAGE, CV_CONFIDENCE)
 
 
def detect_notification_x():
    """Try to find the notification X button on screen using CV."""
    if not os.path.exists(NOTIFICATION_X_IMAGE):
        return None
    return detect_image_on_screen(NOTIFICATION_X_IMAGE, CV_CONFIDENCE)
 
 
def close_notification():
    """Check for notification popup and close it if found."""
    global notifications_closed
 
    location = detect_notification_x()
    if location:
        x, y = location
        print(f"[CV] Found notification at ({x}, {y}) - closing!")
        pyautogui.click(x, y)
        notifications_closed += 1
        time.sleep(0.2)
        return True
    return False
 
 
def detect_upgrade(image_path):
    """Try to find an upgrade icon on screen using CV."""
    if not os.path.exists(image_path):
        return None
    return detect_image_on_screen(image_path, UPGRADE_CV_CONFIDENCE)
 
 
def detect_all_upgrades():
